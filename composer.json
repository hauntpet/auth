{
    "name": "hauntpet/auth",
    "description": "Add the ability to authenticate using HauntID.",
    "type": "library",
    "license": "proprietary",
    "authors": [
        {
            "name": "Lumite Studios",
            "email": "haunt@lumitestudios.com"
        }
    ],
    "require": {
        "illuminate/support": "^9.14"
    },
    "autoload": {
        "psr-4": {
            "HauntPet\\Auth\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "HauntPet\\Auth\\AuthServiceProvider"
            ],
            "aliases": {
                "HauntID": "HauntPet\\Auth\\Facades\\HauntID"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
